{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(**/.env)",
      "Read(./.env.local)",
      "Read(**/.env.local)",
      "Read(./.env.*.local)",
      "Read(**/.env.*.local)",
      "Read(./.env.development)",
      "Read(**/.env.development)",
      "Read(./.env.production)",
      "Read(**/.env.production)",
      "Read(./.env.staging)",
      "Read(**/.env.staging)",
      "Read(./.env.test)",
      "Read(**/.env.test)",
      "Write(./.env)",
      "Write(**/.env)",
      "Write(./.env.local)",
      "Write(**/.env.local)",
      "Write(./.env.*.local)",
      "Write(**/.env.*.local)",
      "Edit(./.env)",
      "Edit(**/.env)",
      "Edit(./.env.local)",
      "Edit(**/.env.local)",
      "Edit(./.env.*.local)",
      "Edit(**/.env.*.local)"
    ]
  }
}
